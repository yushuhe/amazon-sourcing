{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pip install -r requirements.txt",
  "functions": {
    "main.py": {
      "maxDuration": 30,
      "includeFiles": "cloud-functions/data/**",
      "excludeFiles": "{src/**,tests/**,output/**,.edgeone/**,.cursor/**,.ralph/**,.pytest_cache/**,scripts/**}"
    }
  }
}

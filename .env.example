# Amazon marketplace domain
AMAZON_DOMAIN=amazon.com
AMAZON_BASE_URL=https://www.amazon.com

# Playwright settings
HEADLESS=true
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=5.0
MAX_RETRIES=3

# Optional HTTP/S proxy (e.g. http://user:pass@host:port)
PROXY_URL=

# Default scrape limits
DEFAULT_TOP_N=20
DEFAULT_MAX_REVIEWS=10
DEFAULT_SEARCH_PAGES=8

# Output directory
OUTPUT_DIR=output

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Price verification (parallel tabs)
PRICE_VERIFY_CONCURRENCY=5
PRICE_VERIFY_DELAY=0.5
